<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestion des Produits</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'JetBrains Mono', monospace;
      background: #0a0a0a;
      min-height: 100vh;
      padding: 40px 20px;
      color: #e5e5e5;
    }
    .container {
      max-width: 1100px;
      margin: 0 auto;
    }
    .header {
      text-align: center;
      margin-bottom: 40px;
    }
    .header h1 {
      color: #ff3333;
      font-size: 2.5rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 4px;
      margin-bottom: 8px;
    }
    .header .subtitle {
      color: #666;
      font-size: 0.9rem;
      letter-spacing: 2px;
    }
    .card {
      background: #111;
      border: 1px solid #222;
      border-radius: 12px;
      overflow: hidden;
    }
    .card-header {
      background: linear-gradient(90deg, #ff3333 0%, #cc0000 100%);
      padding: 20px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .card-header h2 {
      color: #fff;
      font-size: 1.1rem;
      font-weight: 600;
      letter-spacing: 1px;
    }
    .btn-add {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #0a0a0a;
      color: #ff3333;
      padding: 10px 20px;
      text-decoration: none;
      border-radius: 6px;
      font-size: 0.85rem;
      font-weight: 600;
      border: 1px solid #ff3333;
      transition: all 0.2s ease;
    }
    .btn-add:hover {
      background: #ff3333;
      color: #0a0a0a;
    }
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      padding: 30px;
    }
    .product-card {
      background: #0a0a0a;
      border: 1px solid #222;
      border-radius: 8px;
      padding: 24px;
      transition: all 0.2s ease;
    }
    .product-card:hover {
      border-color: #ff3333;
      box-shadow: 0 0 20px rgba(255, 51, 51, 0.15);
    }
    .product-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 1px solid #222;
    }
    .product-name {
      font-size: 1.1rem;
      font-weight: 600;
      color: #fff;
    }
    .product-id {
      font-size: 0.7rem;
      color: #444;
    }
    .product-details {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 20px;
    }
    .product-detail {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .product-detail span:first-child {
      color: #666;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .product-detail span:last-child {
      color: #ff3333;
      font-weight: 600;
      font-size: 1rem;
    }
    .product-actions {
      display: flex;
      gap: 10px;
    }
    .btn {
      flex: 1;
      padding: 10px;
      border: 1px solid #333;
      border-radius: 6px;
      font-size: 0.8rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      text-align: center;
      transition: all 0.2s ease;
      font-family: 'JetBrains Mono', monospace;
    }
    .btn-edit {
      background: transparent;
      color: #ffaa00;
      border-color: #ffaa00;
    }
    .btn-edit:hover {
      background: #ffaa00;
      color: #0a0a0a;
    }
    .btn-delete {
      background: transparent;
      color: #ff3333;
      border-color: #ff3333;
    }
    .btn-delete:hover {
      background: #ff3333;
      color: #0a0a0a;
    }
    .empty {
      text-align: center;
      padding: 80px 30px;
    }
    .empty-icon {
      font-size: 4rem;
      margin-bottom: 20px;
      filter: grayscale(100%);
    }
    .empty p {
      color: #444;
      font-size: 0.9rem;
      letter-spacing: 1px;
    }
    .glow {
      text-shadow: 0 0 10px rgba(255, 51, 51, 0.5);
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1 class="glow">Products</h1>
      <p class="subtitle"></p>
    </div>
    
    <div class="card">
      <div class="card-header">
        <h2>LISTE DES PRODUITS</h2>
        <a href="/add" class="btn-add">
          <span>+</span> ADD PRODUCT
        </a>
      </div>
      
      <% if (products.length === 0) { %>
        <div class="empty">
          <div class="empty-icon">📦</div>
          <p>// no products found<br>add your first product</p>
        </div>
      <% } else { %>
        <div class="products-grid">
          <% products.forEach(product => { %>
            <div class="product-card">
              <div class="product-header">
                <div class="product-name"><%= product.name %></div>
                <div class="product-id">#<%= product._id.toString().slice(-6) %></div>
              </div>
              <div class="product-details">
                <div class="product-detail">
                  <span>price</span>
                  <span><%= product.price.toFixed(2) %> €</span>
                </div>
                <div class="product-detail">
                  <span>quantity</span>
                  <span><%= product.quantity %></span>
                </div>
              </div>
              <div class="product-actions">
                <a href="/edit/<%= product._id %>" class="btn btn-edit">EDIT</a>
                <form action="/delete/<%= product._id %>?_method=DELETE" method="POST">
                  <button type="submit" class="btn btn-delete" onclick="return confirm('Delete this product?')">DELETE</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
